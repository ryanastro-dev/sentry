{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentry",
  "version": "0.1.0",
  "identifier": "com.ryan.sentry",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sentry",
        "width": 1200,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "../../watcher-zig/zig-out/bin/sentry-watcher"
    ]
  }
}
